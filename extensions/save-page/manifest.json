{
  "manifest_version": 3,
  "name": "Research Center Save Page",
  "version": "0.1.0",
  "description": "Capture the current tab and save it into the local Research Center app.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:8000/*", "http://127.0.0.1:8000/*"],
  "action": {
    "default_title": "Save Page",
    "default_popup": "popup.html"
  }
}

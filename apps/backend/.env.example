APP_ENV=development
APP_NAME=Research Center
API_PREFIX=/api
DATABASE_URL=sqlite+pysqlite:///./research_center.db
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
SECRET_KEY=change-me
ENCRYPTION_KEY=change-me
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
LOGIN_RATE_LIMIT_LOCKOUT_MINUTES=30
FRONTEND_ORIGIN=http://localhost:5173
AUTO_CREATE_SCHEMA=true
SEED_DEMO_DATA=true
TIMEZONE=Europe/Zurich
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_SECONDS=30
AI_DAILY_COST_LIMIT_USD=10.0
AI_BUDGET_RESERVATION_TTL_MINUTES=120
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_TTS_CREDENTIALS_JSON=
GOOGLE_TTS_API_BASE_URL=https://texttospeech.googleapis.com/v1
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_TTS_TIMEOUT_SECONDS=60
GOOGLE_TTS_LANGUAGE_CODE=en-US
GOOGLE_TTS_VOICE_NAME=en-US-Studio-O
GOOGLE_TTS_SSML_GENDER=FEMALE
GOOGLE_TTS_AUDIO_ENCODING=MP3
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_PITCH=0.0
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
ENABLE_EMBEDDINGS=false
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_FORMAT=auto
METRICS_ENABLED=true
METRICS_PATH=/metrics
METRICS_TOKEN=
WORKER_METRICS_HOST=127.0.0.1
WORKER_METRICS_PORT=
DATABASE_BACKUP_DIR=.backups/database
DATABASE_BACKUP_RETENTION_COUNT=14

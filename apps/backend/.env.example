APP_ENV=development
APP_NAME=Research Center
API_PREFIX=/api
SECRET_KEY=change-me
ENCRYPTION_KEY=change-me
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
LOGIN_RATE_LIMIT_LOCKOUT_MINUTES=30
AUTO_CREATE_SCHEMA=true
FRONTEND_ORIGIN=http://localhost:8000
TIMEZONE=Europe/Zurich

# Durable knowledge state lives in the vault submodule at the repo root by default.
# Override this only if you want the vault somewhere else on disk.
VAULT_ROOT_DIR=vault
VAULT_GIT_ENABLED=true
VAULT_GIT_REMOTE_NAME=origin
VAULT_GIT_REMOTE_URL=https://github.com/jschweiz/research-vault
VAULT_GIT_BRANCH=main
VAULT_GIT_COMMIT_PREFIX=vault-sync

# Codex advanced-enrichment runtime.
CODEX_BINARY=codex
CODEX_MODEL=
CODEX_PROFILE=
CODEX_TIMEOUT_MINUTES=20
CODEX_SEARCH_ENABLED=true
CODEX_ADD_DIRS=apps/backend
CODEX_COMPILE_BATCH_SIZE=12

# Unsynced local state for pairing tokens, auth material, and AI budget tracking.
LOCAL_STATE_DIR=apps/backend/.local-state
DEFAULT_JOB_LEASE_TTL_SECONDS=600

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_SECONDS=30
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_TIMEOUT_SECONDS=45
AI_DAILY_COST_LIMIT_USD=10.0
AI_BUDGET_RESERVATION_TTL_MINUTES=120
AI_TRACE_RETENTION_DAYS=30

GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_TTS_CREDENTIALS_JSON=
GMAIL_INGEST_EMAIL=
GMAIL_INGEST_APP_PASSWORD=
GMAIL_INGEST_ACCESS_TOKEN=
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GOOGLE_TTS_API_BASE_URL=https://texttospeech.googleapis.com/v1
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_TTS_TIMEOUT_SECONDS=60
GOOGLE_TTS_LANGUAGE_CODE=en-US
GOOGLE_TTS_VOICE_NAME=en-US-Studio-O
GOOGLE_TTS_SSML_GENDER=FEMALE
GOOGLE_TTS_AUDIO_ENCODING=MP3
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_PITCH=0.0
AUDIO_CACHE_DIR=.cache/audio_briefs

ENABLE_EMBEDDINGS=false
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_FORMAT=auto
METRICS_ENABLED=true
METRICS_PATH=/metrics
METRICS_TOKEN=

LOCAL_SERVER_BASE_URL=http://localhost:8000
HOSTED_VIEWER_URL=
LOCAL_PAIRING_TOKEN_TTL_MINUTES=30
LOCAL_CONTROL_TOKEN_MAX_AGE_DAYS=180
LOCAL_WEB_MODE=local
PUBLISHED_WEB_DIST_DIR=apps/web/dist-published
VAULT_SOURCE_PIPELINES_ENABLED=true

# Legacy exporter only. Not used by the runtime app.
DATABASE_URL=sqlite+pysqlite:///./research_center.db
